# Copy to .env for local development. Do not commit real secrets.
#
# Configure model credentials through OpenClaw's secrets/config tooling:
#   npm run openclaw:configure -- --section model
#   npm run openclaw -- secrets configure
#
# Common provider examples:
OPENCLAW_PROFILE=openui
OPENUI_OPENCLAW_MODEL=
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_HTTP_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

VITE_OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789

# Optional: read-only Figma personal access token for design import scripts.
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=2zA19y0kTx79oDOOfcNRJN
FIGMA_NODE_ID=36:6797

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

